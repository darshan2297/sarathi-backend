# Sarathi backend config — copy to .env and fill in. All vars are prefixed SARATHI_.

# --- LLM provider chain ---
# "router" = OpenRouter (primary) -> Ollama (fallback, degraded) -> stub (dev, no keys)
SARATHI_LLM_PROVIDER=router

# OpenRouter (primary; Hindi-strong). Get a key at https://openrouter.ai/keys
# Leave blank to skip OpenRouter (router will use Ollama, then stub).
SARATHI_OPENROUTER_API_KEY=
SARATHI_OPENROUTER_MODEL_STRONG=qwen/qwen-2.5-72b-instruct
SARATHI_OPENROUTER_MODEL_CHEAP=qwen/qwen-2.5-7b-instruct

# Ollama (fallback; local, Hindi-capable). Run:  ollama serve  &&  ollama pull qwen2.5:7b
# Enable only when the daemon is actually running, else it's skipped (dev stays fast).
SARATHI_OLLAMA_ENABLED=false
SARATHI_OLLAMA_HOST=http://localhost:11434
SARATHI_OLLAMA_MODEL=qwen2.5:7b

# Resilience
SARATHI_REQUEST_TIMEOUT_S=30
SARATHI_MAX_RETRIES=2
SARATHI_CIRCUIT_FAIL_THRESHOLD=3
SARATHI_CIRCUIT_RESET_S=20

# Caching / budget
SARATHI_CACHE_ENABLED=true
SARATHI_TOKEN_BUDGET_PER_TURN=4000
SARATHI_LATENCY_BUDGET_P95_MS=6000

# Set false in production so real outages surface instead of silently using the stub.
SARATHI_ALLOW_STUB_FALLBACK=true
